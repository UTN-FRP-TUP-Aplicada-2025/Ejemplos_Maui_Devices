<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Ejemplo_Maui_Hibrida.MainPage"
             xmlns:controls="clr-namespace:Ejemplo_Maui_Hibrida.Controls">

    <Grid>
        <Grid RowDefinitions="Auto, *">
            <HorizontalStackLayout Grid.Row="0">
                <Button Text="Go URL" Command="{Binding GoUrlCommand}" Margin="10"/>
            </HorizontalStackLayout>

            <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}" IsVisible="{Binding MostrarNavegador}">
                <WebView x:Name="webView" Source="{Binding Url}">
                    <WebView.Behaviors>
                        <toolkit:EventToCommandBehavior EventName="Navigating" Command="{Binding NavigatingCommand}" />
                        <toolkit:EventToCommandBehavior EventName="Navigated" Command="{Binding NavigatedCommand}" />
                    </WebView.Behaviors>
                </WebView>
            </RefreshView>
        </Grid>

        <controls:GpsStatusOverlayView BindingContext="{Binding GpsOverlayViewModel}"/>
    </Grid>

</ContentPage>
