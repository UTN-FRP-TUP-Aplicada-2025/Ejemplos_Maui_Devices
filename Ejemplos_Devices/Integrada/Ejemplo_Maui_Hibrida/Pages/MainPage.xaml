<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:controls="clr-namespace:Ejemplo_Maui_Hibrida.Controls"
             xmlns:pageModels="clr-namespace:Ejemplo_Maui_Hibrida.ViewModels"
             xmlns:conv="clr-namespace:Ejemplo_Maui_Hibrida.Converters"
             x:Class="Ejemplo_Maui_Hibrida.MainPage"
             x:DataType="pageModels:MainViewModel"
             NavigationPage.HasNavigationBar="False"
             x:Name="page"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ContentPage.Resources>
        <conv:WebNavigatingEventArgsConverter x:Key="NavigatingConverter" />
        <conv:WebNavigatedEventArgsConverter  x:Key="NavigatedConverter" />
        <toolkit:InvertedBoolConverter x:Key="InvertedBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">
        <!-- El WebView se ve SOLO cuando el overlay de Red está oculto:
             así nunca se muestra la página de error del navegador. -->
        <RefreshView  Grid.Row="0" IsRefreshing="{Binding IsRefreshing}"
                      IsVisible="{Binding NetworkOverlayViewModel.IsVisible, Converter={StaticResource InvertedBool}}">
            <WebView x:Name="webView" Source="{Binding Url}">
                <WebView.Behaviors>
                    <toolkit:EventToCommandBehavior EventName="Navigating"
                                EventArgsConverter="{StaticResource NavigatingConverter}"
                                Command="{Binding BindingContext.NavigatingCommand, Source={x:Reference page}}" />

                    <toolkit:EventToCommandBehavior EventName="Navigated"
                                EventArgsConverter="{StaticResource NavigatedConverter}"
                                Command="{Binding BindingContext.NavigatedCommand, Source={x:Reference page}}" />
                </WebView.Behaviors>
            </WebView>
        </RefreshView>

        <!-- El orden = prioridad visual: el último declarado queda arriba.
             GPS primero; Red después; Llamada al final (máxima prioridad). -->
        <controls:StatusOverlayView BindingContext="{Binding GpsOverlayViewModel}"/>

        <controls:StatusOverlayView BindingContext="{Binding NetworkOverlayViewModel}"/>

        <controls:StatusOverlayView BindingContext="{Binding CallOverlayViewModel}"/>

        <HorizontalStackLayout Grid.Row="1">
            <Button Text="Geo Posicionar" Command="{Binding TakeGPSCommand}" Margin="10"/>
            <Button Text="Llamar" Command="{Binding TakePhoneCommand}" Margin="10"/>
        </HorizontalStackLayout>

    </Grid>

</ContentPage>
