<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ejemplo_Maui_GPS.Pages.MainPage">

    <ScrollView>

        <VerticalStackLayout Spacing="10" Margin="10">
            <Label Text="{Binding Coordenadas}"/>
            <Button x:Name="btnMostrarCoordenadas" Text="Mostrar" Clicked="OnGetGeoLocalizacion_Clicked"/>
            <Button x:Name="btnCancelarCoordenadas" Text="Cancelar" Clicked="OnCancelarGeoLocalizacion_Clicked"/>
            <Button Text="Mostrar en mapa" Clicked="OnMostrarLocalizacionEnMapaClicked"/>
        </VerticalStackLayout>

    </ScrollView>

</ContentPage>
