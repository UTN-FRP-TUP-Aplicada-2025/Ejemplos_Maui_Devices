<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Ejemplo_Maui_GPS.Controls"
             x:Class="Ejemplo_Maui_GPS.Pages.MainPage"
             Title="GPS">

    <Grid>

        <!-- Contenido principal: visible cuando el overlay está oculto. -->
        <VerticalStackLayout IsVisible="{Binding MostrandoContenido}" Spacing="20" Padding="30" VerticalOptions="Center" HorizontalOptions="Center">
            <Label Text="{Binding Coordenadas}" FontSize="18" HorizontalTextAlignment="Center"/>
            <Button Text="Obtener ubicación" Command="{Binding ObtenerUbicacionCommand}"/>
            <Button Text="Cancelar" Command="{Binding CancelarCommand}"/>
            <Button Text="Mostrar en mapa" Command="{Binding MostrarEnMapaCommand}"/>
        </VerticalStackLayout>

        <!-- Componente reutilizable: maneja espera + permisos. Su BindingContext es el GpsOverlayViewModel del VM padre. -->
        <controls:GpsStatusOverlayView BindingContext="{Binding Overlay}"/>

    </Grid>

</ContentPage>
